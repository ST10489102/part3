<Window x:Class="PART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot"
        Height="700"
        Width="450"
        Background="#0B0F1A">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#101A2E"
                CornerRadius="15"
                Padding="10"
                BorderBrush="#4DA3FF"
                BorderThickness="2">

            <ScrollViewer x:Name="ScrollViewer"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">

            <TextBox x:Name="InputTextBox"
                     Width="300"
                     Height="40"
                     Background="#1A2340"
                     Foreground="White"
                     BorderBrush="#FF4DA6"
                     CaretBrush="#FF4DA6"
                     Padding="8"
                     FontSize="14"/>

            <Button Content="Send"
                    Width="100"
                    Height="40"
                    Margin="10,0,0,0"
                    Background="#FF4DA6"
                    Foreground="White"
                    Click="SendButton_Click"/>
        </StackPanel>

    </Grid>
</Window>